# These values are auto-detected from `npx supabase status` at
# `npm run dev` boot via the supabase-local-env Vite plugin. Copying
# this to .env.local is optional and only needed if you want to point
# local dev at a non-default Supabase URL or key. Production deploys
# (Vercel) MUST set these values explicitly.

VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=<publishable-key-from-supabase-status>
